<!-- 

This is the main layout file — all pages likely render inside this.
Changes here affect shared elements like navbar, footer, and site-wide HTML structure.

  -->

<!DOCTYPE html>
<html>
  <head>
    <!-- xterm CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.3.0/css/xterm.css" />

    <%= yield :head %>

    <!-- PWA manifest (optional) -->
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Stylesheets -->
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Bootstrap -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  </head>

  <body>
    <!-- Move the login display into the body -->
    <div>
      <% if logged_in? %>
        <p>Welcome, <%= current_user.email %>!</p>
        <%= link_to "logout", logout_path, method: :delete, data: { turbo: false }, class: "logout-button" %>
      <% else %>
        <%= link_to "Login", login_path %>
        <%= link_to "Sign Up", signup_path %>
      <% end %>
    </div>
  </nav>
  <body>
    <%= yield %>
  </body>
</html>
